{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "buildCommand": "npm install --include=dev && npm run build && cd .medusa/server && npm install"
  },
  "deploy": {
    "startCommand": "cd .medusa/server && npm run start",
    "preDeployCommand": "cd .medusa/server && npm run predeploy",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ALWAYS"
  }
}
